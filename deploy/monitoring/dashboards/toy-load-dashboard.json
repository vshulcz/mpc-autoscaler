{
  "title": "Toy Load Dashboard",
  "uid": "toy-load",
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "toy-load"
  ],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(toy_http_requests_total{path=\"/work\"}[1m]))",
          "legendFormat": "rps",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(toy_http_requests_total{path=\"/work\",code=~\"5..\"}[1m]))",
          "legendFormat": "5xx rps",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 7
      }
    },
    {
      "type": "timeseries",
      "title": "Latency Quantiles",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(toy_http_request_duration_seconds_bucket{path=\"/work\"}[1m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(toy_http_request_duration_seconds_bucket{path=\"/work\"}[1m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(toy_http_request_duration_seconds_bucket{path=\"/work\"}[1m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "stat",
      "title": "In-Flight Requests",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "sum(toy_in_flight_requests)",
          "legendFormat": "inflight",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 4,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Replicas",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{deployment=\"toy-load\"}",
          "legendFormat": "available",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        },
        {
          "expr": "kube_deployment_spec_replicas{deployment=\"toy-load\"}",
          "legendFormat": "desired",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 7,
        "w": 8,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"toy-load-.*\"}[1m]))",
          "legendFormat": "cpu",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "toy-prometheus"
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{pod=~\"toy-load-.*\"})",
          "legendFormat": "memory",
          "datasource": {
            "type": "prometheus",
            "uid": "toy-prometheus"
          }
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      }
    }
  ]
}
