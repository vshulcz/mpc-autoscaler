{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Toy Load Dashboard",
  "uid": "toy-load",
  "timezone": "",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "tags": [
    "toy-load",
    "autoscaling"
  ],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "label": "Namespace",
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(toy_http_requests_total, namespace)",
        "query": "label_values(toy_http_requests_total, namespace)",
        "refresh": 2,
        "current": {
          "text": "default",
          "value": "default"
        }
      },
      {
        "name": "job",
        "type": "query",
        "label": "Prometheus job",
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(toy_http_requests_total{namespace=\"$namespace\"}, job)",
        "query": "label_values(toy_http_requests_total{namespace=\"$namespace\"}, job)",
        "refresh": 2,
        "current": {
          "text": "toy-load-toy-load",
          "value": "toy-load-toy-load"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(toy_http_requests_total{namespace=\"$namespace\",job=\"$job\",path=\"/work\"}[1m]))",
          "legendFormat": "rps"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(toy_http_requests_total{namespace=\"$namespace\",job=\"$job\",path=\"/work\",code=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "5xx rps"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 }
    },
    {
      "type": "timeseries",
      "title": "Latency Quantiles",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(toy_http_request_duration_seconds_bucket{namespace=\"$namespace\",job=\"$job\",path=\"/work\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(toy_http_request_duration_seconds_bucket{namespace=\"$namespace\",job=\"$job\",path=\"/work\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(toy_http_request_duration_seconds_bucket{namespace=\"$namespace\",job=\"$job\",path=\"/work\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "In-Flight Requests",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(toy_in_flight_requests{namespace=\"$namespace\",job=\"$job\"})",
          "legendFormat": "inflight"
        }
      ],
      "gridPos": { "x": 12, "y": 7, "w": 4, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Scraped Targets",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(up{namespace=\"$namespace\",job=\"$job\"})",
          "legendFormat": "up"
        },
        {
          "expr": "count(up{namespace=\"$namespace\",job=\"$job\"})",
          "legendFormat": "targets"
        }
      ],
      "gridPos": { "x": 16, "y": 7, "w": 8, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Process CPU",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(process_cpu_seconds_total{namespace=\"$namespace\",job=\"$job\"}[1m]))",
          "legendFormat": "cores"
        }
      ],
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Resident Memory",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(process_resident_memory_bytes{namespace=\"$namespace\",job=\"$job\"})",
          "legendFormat": "bytes"
        }
      ],
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 }
    }
  ]
}
